# Normalize line endings so installers work on every platform.
* text=auto

# Windows shells REQUIRE CRLF — LF-only batch/PS files misparse.
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.ps1  text eol=crlf

# POSIX shell scripts REQUIRE LF — CRLF breaks the shebang / `bash`.
*.sh   text eol=lf

# Keep Python and docs LF everywhere for consistent diffs.
*.py   text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
